<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.GoMenuDemo" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">#FF6B9E</item>
        <item name="colorPrimaryVariant">#E85A8A</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">#FFD166</item>
    </style>

    <style name="Widget.Demo.PayButton" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">36dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Demo.PayButton.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">36dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Remote / Local Kiosk launch group (deeper tint, smaller text for 2×2 layout) -->
    <style name="Widget.Demo.KioskRouteButton" parent="Widget.Demo.PayButton">
        <item name="backgroundTint">@color/kiosk_route_button_tint</item>
        <item name="android:textColor">@color/kiosk_route_button_label</item>
        <item name="android:textSize">12sp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:lines">2</item>
        <item name="android:gravity">center</item>
    </style>
</resources>
