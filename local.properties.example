sdk.dir=C\:\\Users\\YOUR_USER\\AppData\\Local\\Android\\Sdk

# Alliance participant: GPOS (ordering / initiator A-side)
# Gateway /init uses code + key → NATS token
PARTICIPANT_CODE=GPOS
PARTICIPANT_KEY=

# Must match posrouter-kiosk on the same lane
TERMINAL_ID=TID001
EZYPOS_MID=

# Optional: Vercel Preview Gateway (omit for production default)
# GATEWAY_BASE_URL=https://preview.posrouter.com

# SDK source (pick one):
# useCompositeSdk=true   — link ../sdk-android source (internal dev)
# useMavenSdk=true       — GitHub Packages (see README)
useCompositeSdk=false
useMavenSdk=false

# GitHub Packages credentials (required when useMavenSdk=true)
gpr.user=YOUR_GITHUB_USERNAME
gpr.key=ghp_...
